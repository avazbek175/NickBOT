# ── Required ──────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# ── Database (use cloud: Neon, Supabase, etc.) ────────────────────────
DB_HOST=ep-cool-123456.us-east-2.aws.neon.tech
DB_PORT=5432
DB_NAME=nickforge
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=require

# ── Redis / KV (use Upstash or Vercel KV) ─────────────────────────────
REDIS_HOST=us1-fluent-bear-12345.upstash.io
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password

# ── Bot config ────────────────────────────────────────────────────────
BOT_NAME=NickForge AI
BOT_DESCRIPTION=Professional Nickname Generator
BOT_LANG=uz

# ── Features ──────────────────────────────────────────────────────────
FORCE_JOIN_ENABLED=true
REFERRAL_ENABLED=true
DAILY_BONUS_ENABLED=true
DAILY_BONUS_COINS=50
REFERRAL_COINS=100

LOG_LEVEL=INFO
MAINTENANCE_MODE=false

# ── Vercel (auto-set by Vercel) ───────────────────────────────────────
VERCEL_URL=
VERCEL_ENV=
